# Copy this file to `.env.local` and fill in your Supabase project credentials.
# Get them from: https://app.supabase.com -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (DO NOT expose to client). Required for Location Breakdown until
# get_location_breakdown is SECURITY DEFINER in Supabase (see supabase/rpc/get_location_breakdown.sql).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
