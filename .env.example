# Copy to `.env.local` and fill in Supabase credentials.
# Project Settings → API: https://app.supabase.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to the browser or commit real values.
# Required for Admin → GA4 Page Views (reads dealer list under RLS).
# Also used by location-breakdown API fallback when RPC returns [].
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Pipeline Step 3: build_smart_final_data (hoot) or build_smart_final_data_scrap (scrap).
# Edge functions: supabase/functions/smart-master-sync and smart-master-sync-scrap.

# Required for Admin Pipeline Step 1 (GA4 API → smart_ga4_page_data).
# RECOMMENDED — point at your downloaded Google key file (keep outside git):
# GCP_SERVICE_ACCOUNT_JSON_PATH=./secrets/gcp-sa.json
#
# OR one-line minified JSON (must use double quotes inside; no line breaks):
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
#
# OR base64 (run: node scripts/encode-gcp-key.mjs path/to/key.json):
# GCP_SERVICE_ACCOUNT_JSON=<base64-string>

# Server-only — Admin pipeline dealers + sync (same as above if not set separately).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
