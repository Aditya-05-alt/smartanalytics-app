# Copy to `.env.local` and fill in Supabase credentials.
# Project Settings → API: https://app.supabase.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to the browser or commit real values.
# Optional: location-breakdown API route fallback when RPC is not deployed.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
